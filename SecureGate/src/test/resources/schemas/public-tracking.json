{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "required": ["trackingCode", "status", "serviceLevel", "origin", "destination", "createdAt", "events"],
  "properties": {
    "trackingCode": { "type": "string" },
    "status": { "type": "string" },
    "serviceLevel": { "type": "string", "enum": ["EXPRESS", "STANDARD", "ECONOMY"] },
    "origin": {
      "type": "object",
      "required": ["city", "country"],
      "properties": { "city": { "type": "string" }, "country": { "type": "string" } }
    },
    "destination": {
      "type": "object",
      "required": ["city", "country"],
      "properties": { "city": { "type": "string" }, "country": { "type": "string" } }
    },
    "estimatedDeliveryAt": { "type": ["string", "null"] },
    "createdAt": { "type": "string" },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["status", "occurredAt"],
        "properties": {
          "status": { "type": "string" },
          "location": { "type": ["string", "null"] },
          "description": { "type": ["string", "null"] },
          "occurredAt": { "type": "string" }
        }
      }
    }
  }
}
