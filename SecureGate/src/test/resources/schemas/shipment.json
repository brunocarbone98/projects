{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "required": ["id", "trackingCode", "status", "serviceLevel", "origin", "destination", "parcel", "priceCents", "currency", "createdAt", "events"],
  "properties": {
    "id": { "type": "string" },
    "trackingCode": { "type": "string" },
    "status": { "type": "string" },
    "serviceLevel": { "type": "string", "enum": ["EXPRESS", "STANDARD", "ECONOMY"] },
    "priceCents": { "type": "integer" },
    "currency": { "type": "string" },
    "zoneCode": { "type": "string" },
    "estimatedDeliveryAt": { "type": ["string", "null"] },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" },
    "parcel": {
      "type": "object",
      "required": ["weightGrams", "lengthCm", "widthCm", "heightCm"]
    },
    "origin": {
      "type": "object",
      "required": ["contactName", "city", "country"]
    },
    "destination": {
      "type": "object",
      "required": ["contactName", "city", "country"]
    },
    "events": { "type": "array" }
  }
}
