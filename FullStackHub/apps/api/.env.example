# Copy to .env and adjust. Never commit the real .env.
DATABASE_URL="postgresql://shipping:shipping@localhost:5432/shipping_hub?schema=public"

# Auth — use long random strings in production.
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
ACCESS_TOKEN_TTL="900"        # seconds (15 min)
REFRESH_TOKEN_TTL_DAYS="7"

PORT="4000"
# Comma-separated origins allowed to call the API (the web app in dev).
CORS_ORIGINS="http://localhost:3000"
# Public base URL of the web app, used to build tracking links.
PUBLIC_WEB_URL="http://localhost:3000"

# Python microservices (Phase 4).
PRICING_SERVICE_URL="http://localhost:8001"
LABELS_SERVICE_URL="http://localhost:8002"

# Notifications (Phase 6, all optional). Without these, email is logged (no-op)
# and no webhook is sent.
RESEND_API_KEY=""
RESEND_FROM="Shipping Hub <noreply@shippinghub.test>"
WEBHOOK_URL=""
WEBHOOK_SECRET=""
